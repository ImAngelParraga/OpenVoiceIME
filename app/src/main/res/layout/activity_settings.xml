<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/openime_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="32dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/openime_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/versionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/version_placeholder"
            android:textColor="@color/openime_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_server"
            android:textColor="@color/openime_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_preset"
            android:textColor="@color/openime_muted" />

        <Spinner
            android:id="@+id/providerPresetSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_server_url"
            android:textColor="@color/openime_muted" />

        <EditText
            android:id="@+id/baseUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:singleLine="true"
            android:textColor="@color/openime_text"
            android:textColorHint="@color/openime_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_model"
            android:textColor="@color/openime_muted" />

        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <EditText
            android:id="@+id/customModelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_custom_model"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/openime_text"
            android:textColorHint="@color/openime_muted"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_api_token"
            android:textColor="@color/openime_muted" />

        <EditText
            android:id="@+id/tokenInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:singleLine="true"
            android:textColor="@color/openime_text"
            android:textColorHint="@color/openime_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_custom_preset"
            android:textColor="@color/openime_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/presetNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/hint_preset_name"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/openime_text"
            android:textColorHint="@color/openime_muted" />

        <Button
            android:id="@+id/savePresetButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="@string/button_save_preset" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_transcription_language"
            android:textColor="@color/openime_muted" />

        <EditText
            android:id="@+id/languageSearchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_search_language"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/openime_text"
            android:textColorHint="@color/openime_muted" />

        <LinearLayout
            android:id="@+id/languageSearchResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <Button
            android:id="@+id/favoriteLanguagesToggleButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:text="@string/settings_quick_languages_format" />

        <LinearLayout
            android:id="@+id/favoriteLanguagesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <Button
            android:id="@+id/testServerButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="@string/button_test_server" />

        <LinearLayout
            android:id="@+id/serverStatusRow"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@color/openime_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/serverStatusIcon"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="•"
                android:textColor="@color/openime_muted"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/serverStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/status_not_tested"
                android:textColor="@color/openime_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/diagnosticPanel"
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_marginTop="8dp"
            android:background="@color/openime_panel"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/diagnosticOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textColor="@color/openime_text"
                android:textIsSelectable="true"
                android:textSize="14sp" />
        </ScrollView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_app_language"
            android:textColor="@color/openime_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/appLanguageSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_behavior"
            android:textColor="@color/openime_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/trailingSpaceCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/settings_append_trailing_space"
            android:textColor="@color/openime_text" />

        <CheckBox
            android:id="@+id/hideAfterSuccessCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_hide_after_insert"
            android:textColor="@color/openime_text" />

        <CheckBox
            android:id="@+id/confirmBeforeInsertCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_confirm_before_insert"
            android:textColor="@color/openime_text" />

        <CheckBox
            android:id="@+id/selectInsertedTextCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_select_inserted_text"
            android:textColor="@color/openime_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_autosave_note"
            android:textColor="@color/openime_muted"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_required_setup"
            android:textColor="@color/openime_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/microphoneStepTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_microphone_step"
            android:textColor="@color/openime_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_microphone_description"
            android:textColor="@color/openime_muted"
            android:textSize="13sp" />

        <Button
            android:id="@+id/permissionButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="@string/button_grant_microphone" />

        <LinearLayout
            android:id="@+id/microphoneStatusRow"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:background="@color/openime_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/microphoneStatusIcon"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="•"
                android:textColor="@color/openime_muted"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/microphoneStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/status_permission_not_granted"
                android:textColor="@color/openime_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/keyboardStepTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_keyboard_step"
            android:textColor="@color/openime_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_keyboard_description"
            android:textColor="@color/openime_muted"
            android:textSize="13sp" />

        <Button
            android:id="@+id/enableImeButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="@string/button_open_keyboard_settings" />

        <LinearLayout
            android:id="@+id/keyboardStatusRow"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:background="@color/openime_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/keyboardStatusIcon"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="•"
                android:textColor="@color/openime_muted"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/keyboardStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/status_keyboard_not_enabled"
                android:textColor="@color/openime_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/metricsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_response_metrics"
            android:textColor="@color/openime_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:background="@color/openime_panel"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/metricsOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textColor="@color/openime_text"
                android:textIsSelectable="true"
                android:textSize="14sp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/copyMetricsButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/button_copy" />

            <Button
                android:id="@+id/shareMetricsButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/button_share" />
        </LinearLayout>

        <Button
            android:id="@+id/resetMetricsButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="@string/button_reset_metrics" />
    </LinearLayout>
</ScrollView>
